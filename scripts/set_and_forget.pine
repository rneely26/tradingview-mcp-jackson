//@version=5
indicator("Alex Gonzalez — Set & Forget", overlay=true, max_lines_count=200, max_labels_count=200)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
// Round Psychological Levels
show_round_levels  = input.bool(true,   "Show Round Psychological Levels",    group="Round Levels")
round_level_spacing = input.float(1000, "Round Level Spacing (pips/points)",  group="Round Levels")

// Timeframes
htf1 = input.timeframe("W",   "Higher TF 1 — Bias",      group="Timeframes")
htf2 = input.timeframe("D",   "Higher TF 2 — Structure", group="Timeframes")
mtf1 = input.timeframe("240", "Mid TF 1 — 4H",           group="Timeframes")
mtf2 = input.timeframe("120", "Mid TF 2 — 2H",           group="Timeframes")

// Structure
swing_length = input.int(10, "Swing Point Length", minval=3, maxval=50, group="Structure")

// Area of Interest
aoi_max_pips = input.float(60, "Max AOI Size (pips)", group="Area of Interest")
show_aoi     = input.bool(true, "Show Area of Interest Zones", group="Area of Interest")

// Patterns
show_patterns    = input.bool(true,  "Show Candlestick Patterns", group="Patterns")
doji_threshold   = input.float(0.1,  "Doji Body % of Range", minval=0.01, maxval=0.5, group="Patterns")

// ─── COLORS ───────────────────────────────────────────────────────────────────
bull_color    = color.new(color.green, 0)
bear_color    = color.new(color.red,   0)
neutral_color = color.new(color.gray,  0)
round_color   = color.new(color.blue,  60)

// ─── STRUCTURE: HH / HL / LH / LL ────────────────────────────────────────────
ph = ta.pivothigh(high, swing_length, swing_length)
pl = ta.pivotlow(low,  swing_length, swing_length)

var float last_ph  = na
var float prev_ph  = na
var float last_pl  = na
var float prev_pl  = na

if not na(ph)
    prev_ph := last_ph
    last_ph  := ph

if not na(pl)
    prev_pl := last_pl
    last_pl  := pl

is_hh = not na(last_ph) and not na(prev_ph) and last_ph > prev_ph
is_hl = not na(last_pl) and not na(prev_pl) and last_pl > prev_pl
is_lh = not na(last_ph) and not na(prev_ph) and last_ph < prev_ph
is_ll = not na(last_pl) and not na(prev_pl) and last_pl < prev_pl

bullish_structure = is_hh and is_hl
bearish_structure = is_lh and is_ll

// Labels for pivot points
if not na(ph)
    label.new(bar_index[swing_length], ph,
              bullish_structure ? "HH" : "LH",
              style=label.style_label_down,
              color=bullish_structure ? bull_color : bear_color,
              textcolor=color.white, size=size.small)

if not na(pl)
    label.new(bar_index[swing_length], pl,
              bullish_structure ? "HL" : "LL",
              style=label.style_label_up,
              color=bullish_structure ? bull_color : bear_color,
              textcolor=color.white, size=size.small)

// ─── MULTI-TIMEFRAME BIAS ─────────────────────────────────────────────────────
htf1_close = request.security(syminfo.tickerid, htf1, close)
htf1_open  = request.security(syminfo.tickerid, htf1, open)
htf2_close = request.security(syminfo.tickerid, htf2, close)
htf2_open  = request.security(syminfo.tickerid, htf2, open)

htf1_bull = htf1_close > htf1_open
htf2_bull = htf2_close > htf2_open

two_tf_bull = htf1_bull and htf2_bull
two_tf_bear = not htf1_bull and not htf2_bull

// ─── ROUND PSYCHOLOGICAL LEVELS ───────────────────────────────────────────────
if show_round_levels and barstate.islast
    nearest_round = math.round(close / round_level_spacing) * round_level_spacing
    for i = -4 to 4
        lvl = nearest_round + i * round_level_spacing
        line.new(bar_index - 100, lvl, bar_index, lvl,
                 color=round_color, width=1, style=line.style_dashed,
                 extend=extend.right)
        label.new(bar_index, lvl, str.tostring(lvl, "#"),
                  style=label.style_label_left, color=color.new(color.blue, 80),
                  textcolor=color.blue, size=size.tiny)

// ─── CANDLESTICK DETECTION ────────────────────────────────────────────────────
o  = open
h  = high
l  = low
c  = close
o1 = open[1]
h1 = high[1]
l1 = low[1]
c1 = close[1]
o2 = open[2]
h2 = high[2]
l2 = low[2]
c2 = close[2]

candle_range = h - l
body         = math.abs(c - o)
upper_wick   = h - math.max(c, o)
lower_wick   = math.min(c, o) - l

// Doji
is_doji = candle_range > 0 and (body / candle_range) <= doji_threshold

// Shooting Star
is_shooting_star = upper_wick >= (2 * body) and lower_wick <= body * 0.5 and c < o

// Bullish Engulfing
is_bull_engulf = c1 < o1 and c > o and c > o1 and o < c1

// Bearish Engulfing
is_bear_engulf = c1 > o1 and c < o and c < o1 and o > c1

// Morning Star
is_morning_star = c2 < o2 and
                  math.abs(c1 - o1) < math.abs(c2 - o2) * 0.5 and
                  c > o and
                  c > (o2 + c2) / 2

// Evening Star
is_evening_star = c2 > o2 and
                  math.abs(c1 - o1) < math.abs(c2 - o2) * 0.5 and
                  c < o and
                  c < (o2 + c2) / 2

// ─── AREA OF INTEREST: REJECTION CHECK ───────────────────────────────────────
// Bullish rejection: wick into AOI, body closes above it
// Bearish rejection: wick into AOI, body closes below it
// We approximate: lower wick >= 2x body for bullish, upper wick >= 2x body for bearish
bullish_rejection = lower_wick >= (2 * body) and c > o
bearish_rejection = upper_wick >= (2 * body) and c < o

// ─── PATTERN LABELS ───────────────────────────────────────────────────────────
if show_patterns
    if is_morning_star
        label.new(bar_index, l - candle_range * 0.5, "Morning Star ★",
                  style=label.style_label_up, color=bull_color, textcolor=color.white, size=size.small)
    if is_evening_star
        label.new(bar_index, h + candle_range * 0.5, "Evening Star ★",
                  style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
    if is_shooting_star
        label.new(bar_index, h + candle_range * 0.3, "Shooting Star",
                  style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
    if is_doji
        label.new(bar_index, h + candle_range * 0.3, "Doji",
                  style=label.style_label_down, color=neutral_color, textcolor=color.white, size=size.small)
    if is_bull_engulf
        label.new(bar_index, l - candle_range * 0.3, "Bull Engulf",
                  style=label.style_label_up, color=bull_color, textcolor=color.white, size=size.small)
    if is_bear_engulf
        label.new(bar_index, h + candle_range * 0.3, "Bear Engulf",
                  style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
    if bullish_rejection and not is_morning_star and not is_bull_engulf
        label.new(bar_index, l - candle_range * 0.3, "Rejection ▲",
                  style=label.style_label_up, color=color.new(color.green, 30), textcolor=color.white, size=size.small)
    if bearish_rejection and not is_evening_star and not is_bear_engulf and not is_shooting_star
        label.new(bar_index, h + candle_range * 0.3, "Rejection ▼",
                  style=label.style_label_down, color=color.new(color.red, 30), textcolor=color.white, size=size.small)

// ─── ENTRY SIGNALS ────────────────────────────────────────────────────────────
bull_pattern = is_morning_star or is_bull_engulf or bullish_rejection or (is_doji and c > o)
bear_pattern = is_evening_star or is_bear_engulf or is_shooting_star or bearish_rejection or (is_doji and c < o)

// Full confluence: 2 TF alignment + structure + candle pattern
long_signal  = two_tf_bull and bullish_structure and bull_pattern
short_signal = two_tf_bear and bearish_structure and bear_pattern

// ─── TP / SL LEVELS ───────────────────────────────────────────────────────────
pip_size = syminfo.mintick * 10

if long_signal
    sl_price = l - (aoi_max_pips * pip_size)
    tp_price = c + ((c - sl_price) * 2)
    label.new(bar_index, l,
              "BUY ▲\nSL: " + str.tostring(sl_price, "#.####") + "\nTP: " + str.tostring(tp_price, "#.####"),
              style=label.style_label_up,
              color=color.new(color.green, 10), textcolor=color.white, size=size.normal)
    line.new(bar_index - 1, tp_price, bar_index + 10, tp_price, color=bull_color,  width=1, style=line.style_dashed)
    line.new(bar_index - 1, sl_price, bar_index + 10, sl_price, color=bear_color,  width=1, style=line.style_dashed)

if short_signal
    sl_price = h + (aoi_max_pips * pip_size)
    tp_price = c - ((sl_price - c) * 2)
    label.new(bar_index, h,
              "SELL ▼\nSL: " + str.tostring(sl_price, "#.####") + "\nTP: " + str.tostring(tp_price, "#.####"),
              style=label.style_label_down,
              color=color.new(color.red, 10), textcolor=color.white, size=size.normal)
    line.new(bar_index - 1, tp_price, bar_index + 10, tp_price, color=bull_color,  width=1, style=line.style_dashed)
    line.new(bar_index - 1, sl_price, bar_index + 10, sl_price, color=bear_color,  width=1, style=line.style_dashed)

// ─── DASHBOARD TABLE ──────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 65), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)

// Header
table.cell(dash, 0, 0, "Set & Forget", text_color=color.white,
           text_size=size.small, bgcolor=color.new(color.navy, 40), text_halign=text.align_left)
table.cell(dash, 1, 0, "Status",       text_color=color.white,
           text_size=size.small, bgcolor=color.new(color.navy, 40), text_halign=text.align_center)

// HTF1 bias
table.cell(dash, 0, 1, htf1 + " Bias",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 1, htf1_bull ? "Bullish ▲" : "Bearish ▼",
           text_color=htf1_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

// HTF2 bias
table.cell(dash, 0, 2, htf2 + " Bias",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 2, htf2_bull ? "Bullish ▲" : "Bearish ▼",
           text_color=htf2_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

// TF alignment
table.cell(dash, 0, 3, "TF Alignment",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 3, two_tf_bull ? "Bull ✓" : two_tf_bear ? "Bear ✓" : "Conflict ✗",
           text_color=two_tf_bull ? bull_color : two_tf_bear ? bear_color : neutral_color,
           text_size=size.small, text_halign=text.align_center)

// Structure
table.cell(dash, 0, 4, "Structure",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 4, bullish_structure ? "HH + HL ✓" : bearish_structure ? "LH + LL ✓" : "Mixed",
           text_color=bullish_structure ? bull_color : bearish_structure ? bear_color : neutral_color,
           text_size=size.small, text_halign=text.align_center)

// AOI size note
table.cell(dash, 0, 5, "Max AOI",         text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 5, str.tostring(aoi_max_pips, "#") + " pips",
           text_color=color.white, text_size=size.small, text_halign=text.align_center)

// Signal
table.cell(dash, 0, 6, "Signal",          text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 6, long_signal ? "LONG ▲" : short_signal ? "SHORT ▼" : "Wait…",
           text_color=long_signal ? bull_color : short_signal ? bear_color : neutral_color,
           text_size=size.small, text_halign=text.align_center)

// ─── ALERTS ───────────────────────────────────────────────────────────────────
alertcondition(long_signal,  "Set & Forget — Long",  "Long signal: 2 TF alignment + HH/HL + bullish candle at AOI")
alertcondition(short_signal, "Set & Forget — Short", "Short signal: 2 TF alignment + LH/LL + bearish candle at AOI")
