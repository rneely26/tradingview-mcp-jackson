//@version=5
indicator("Claude Code Set & Forget Strategy", overlay=true, max_lines_count=200, max_labels_count=200)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
show_round_levels   = input.bool(true,   "Show Round Psychological Levels",    group="Round Levels")
round_level_spacing = input.float(1000,  "Round Level Spacing (pips/points)",  group="Round Levels")
htf1                = input.timeframe("W",  "Higher TF 1 — Bias",              group="Timeframes")
htf2                = input.timeframe("D",  "Higher TF 2 — Structure",         group="Timeframes")
swing_length        = input.int(10, "Swing Point Length", minval=3, maxval=50, group="Structure")
aoi_max_pips        = input.float(60,    "Max AOI Size (pips/points)",          group="Area of Interest")
pip_override        = input.float(0.0,   "Pip/Point Size Override (0 = auto)", group="Area of Interest")
show_patterns       = input.bool(true,   "Show Chart Patterns",                 group="Patterns")
pattern_tol_pct     = input.float(1.0,   "Pattern Equality Tolerance (%)",      minval=0.1, maxval=5.0, group="Patterns")
ema_length          = input.int(50,      "EMA Length",                          group="EMA Filter")
show_ema            = input.bool(true,   "Show EMA on Chart",                   group="EMA Filter")

// ─── COLORS ───────────────────────────────────────────────────────────────────
bull_color    = color.new(color.green, 0)
bear_color    = color.new(color.red,   0)
neutral_color = color.new(color.gray,  0)
round_color   = color.new(color.blue,  60)

// ─── PIVOT DETECTION ──────────────────────────────────────────────────────────
ph = ta.pivothigh(high, swing_length, swing_length)
pl = ta.pivotlow(low,  swing_length, swing_length)

// Track 3 most recent pivot highs with bar indices
var float ph1 = na
var float ph2 = na
var float ph3 = na
var int   ph1_idx = na
var int   ph2_idx = na
var int   ph3_idx = na

// Track 3 most recent pivot lows with bar indices
var float pl1 = na
var float pl2 = na
var float pl3 = na
var int   pl1_idx = na
var int   pl2_idx = na
var int   pl3_idx = na

// ─── CHART PATTERN HELPER ─────────────────────────────────────────────────────
// Must be declared before use
within_tol(a, b) =>
    math.abs(a - b) / math.max(math.abs(a), math.abs(b)) <= (pattern_tol_pct / 100)

// ─── STORED NECKLINES (set when pattern forms, cleared after signal fires) ────
// Stored at pattern-formation time so a later pivot update can't corrupt the level
var float db_neckline  = na   // Double Bottom neckline (resistance high between two lows)
var float dt_neckline  = na   // Double Top neckline (support low between two highs)
var float hs_neckline  = na   // Head & Shoulders neckline (avg of troughs)
var float ihs_neckline = na   // Inverted H&S neckline (avg of peaks)

// Pending flags — set true when pattern forms, cleared after neckline break fires
// Required because ta.crossover() breaks when a var float transitions from na → value
var bool db_pending  = false
var bool dt_pending  = false
var bool hs_pending  = false
var bool ihs_pending = false

// Snapshots — capture neckline price before it is cleared, so labels/lines can draw it
var float db_neck_snap  = na
var float dt_neck_snap  = na
var float hs_neck_snap  = na
var float ihs_neck_snap = na

// ─── UPDATE PIVOTS AND CHECK PATTERN FORMATION ────────────────────────────────
if not na(ph)
    ph3     := ph2
    ph3_idx := ph2_idx
    ph2     := ph1
    ph2_idx := ph1_idx
    ph1     := ph
    ph1_idx := bar_index[swing_length]

    // Double Top: two approx-equal highs (ph2, ph1) with a trough (pl1) between them
    // Neckline = pl1 (the low between the two highs). Confirmed when close breaks BELOW it.
    if not na(ph2) and within_tol(ph1, ph2) and not na(pl1) and
       pl1_idx > ph2_idx and pl1_idx < ph1_idx
        dt_neckline := pl1
        dt_pending  := true

    // Head & Shoulders (bearish): left shoulder (ph3), head (ph2 highest), right shoulder (ph1 ≈ ph3)
    // ph1 just fired = right shoulder. Neckline = average of troughs on each side of the head.
    // Confirmed when close breaks BELOW the neckline.
    if not na(ph2) and not na(ph3) and
       ph2 > ph3 and ph2 > ph1 and within_tol(ph1, ph3) and
       not na(pl1) and not na(pl2) and
       pl2_idx > ph3_idx and pl2_idx < ph2_idx and
       pl1_idx > ph2_idx and pl1_idx < ph1_idx
        hs_neckline := (pl1 + pl2) / 2
        hs_pending  := true

if not na(pl)
    pl3     := pl2
    pl3_idx := pl2_idx
    pl2     := pl1
    pl2_idx := pl1_idx
    pl1     := pl
    pl1_idx := bar_index[swing_length]

    // Double Bottom: two approx-equal lows (pl2, pl1) with a peak (ph1) between them
    // Neckline = ph1 (the high between the two lows). Confirmed when close breaks ABOVE it.
    if not na(pl2) and within_tol(pl1, pl2) and not na(ph1) and
       ph1_idx > pl2_idx and ph1_idx < pl1_idx
        db_neckline := ph1
        db_pending  := true

    // Inverted Head & Shoulders (bullish): left shoulder (pl3), head (pl2 lowest), right shoulder (pl1 ≈ pl3)
    // pl1 just fired = right shoulder. Neckline = average of peaks on each side of the head.
    // Confirmed when close breaks ABOVE the neckline.
    if not na(pl2) and not na(pl3) and
       pl2 < pl3 and pl2 < pl1 and within_tol(pl1, pl3) and
       not na(ph1) and not na(ph2) and
       ph2_idx > pl3_idx and ph2_idx < pl2_idx and
       ph1_idx > pl2_idx and ph1_idx < pl1_idx
        ihs_neckline := (ph1 + ph2) / 2
        ihs_pending  := true

// ─── MARKET STRUCTURE: HH / HL / LH / LL ─────────────────────────────────────
is_hh = not na(ph1) and not na(ph2) and ph1 > ph2
is_hl = not na(pl1) and not na(pl2) and pl1 > pl2
is_lh = not na(ph1) and not na(ph2) and ph1 < ph2
is_ll = not na(pl1) and not na(pl2) and pl1 < pl2

bullish_structure = is_hh and is_hl
bearish_structure = is_lh and is_ll

if not na(ph)
    label.new(bar_index[swing_length], ph,
      bullish_structure ? "HH" : "LH",
      style=label.style_label_down,
      color=bullish_structure ? bull_color : bear_color,
      textcolor=color.white, size=size.small)

if not na(pl)
    label.new(bar_index[swing_length], pl,
      bullish_structure ? "HL" : "LL",
      style=label.style_label_up,
      color=bullish_structure ? bull_color : bear_color,
      textcolor=color.white, size=size.small)

// ─── MULTI-TIMEFRAME BIAS ─────────────────────────────────────────────────────
htf1_close = request.security(syminfo.tickerid, htf1,    close)
htf1_open  = request.security(syminfo.tickerid, htf1,    open)
htf2_close = request.security(syminfo.tickerid, htf2,    close)
htf2_open  = request.security(syminfo.tickerid, htf2,    open)
htf3_close = request.security(syminfo.tickerid, "240",   close)
htf3_open  = request.security(syminfo.tickerid, "240",   open)
htf4_close = request.security(syminfo.tickerid, "120",   close)
htf4_open  = request.security(syminfo.tickerid, "120",   open)
htf5_close = request.security(syminfo.tickerid, "60",    close)
htf5_open  = request.security(syminfo.tickerid, "60",    open)
htf6_close = request.security(syminfo.tickerid, "30",    close)
htf6_open  = request.security(syminfo.tickerid, "30",    open)

htf1_bull = htf1_close > htf1_open
htf2_bull = htf2_close > htf2_open
htf3_bull = htf3_close > htf3_open
htf4_bull = htf4_close > htf4_open
htf5_bull = htf5_close > htf5_open
htf6_bull = htf6_close > htf6_open

// All 6 TFs must align — W + D + 4H + 2H + 1H + 30m
multi_tf_bull = htf1_bull and htf2_bull and htf3_bull and htf4_bull and htf5_bull and htf6_bull
multi_tf_bear = not htf1_bull and not htf2_bull and not htf3_bull and not htf4_bull and not htf5_bull and not htf6_bull

tf_bull_count = (htf1_bull ? 1 : 0) + (htf2_bull ? 1 : 0) + (htf3_bull ? 1 : 0) + (htf4_bull ? 1 : 0) + (htf5_bull ? 1 : 0) + (htf6_bull ? 1 : 0)

// ─── EMA FILTER ───────────────────────────────────────────────────────────────
ema_value = ta.ema(close, ema_length)
ema_bull  = close > ema_value
ema_bear  = close < ema_value

plot(show_ema ? ema_value : na, "EMA", color=ema_bull ? bull_color : bear_color, linewidth=2)

// ─── ROUND PSYCHOLOGICAL LEVELS ───────────────────────────────────────────────
if show_round_levels and barstate.islast
    nearest_round = math.round(close / round_level_spacing) * round_level_spacing
    for i = -4 to 4
        lvl = nearest_round + i * round_level_spacing
        line.new(bar_index - 100, lvl, bar_index, lvl,
          color=round_color, width=1, style=line.style_dashed, extend=extend.right)
        label.new(bar_index, lvl, str.tostring(lvl, "#"),
          style=label.style_label_left,
          color=color.new(color.blue, 80), textcolor=color.blue, size=size.tiny)

// ─── CANDLESTICK REJECTION DETECTION ─────────────────────────────────────────
o  = open
h  = high
l  = low
c  = close
o1 = open[1]
h1 = high[1]
l1 = low[1]
c1 = close[1]
o2 = open[2]
h2 = high[2]
c2 = close[2]

candle_range  = h - l
body          = math.abs(c - o)
upper_wick    = h - math.max(c, o)
lower_wick    = math.min(c, o) - l

// Doji — body is very small relative to the candle range
is_doji         = candle_range > 0 and (body / candle_range) <= 0.1

// Shooting Star — long upper wick, small lower wick, bearish close
is_shooting_star = upper_wick >= (2 * body) and lower_wick <= body * 0.5 and c < o

// Engulfing patterns
is_bull_engulf  = c1 < o1 and c > o and c > o1 and o < c1
is_bear_engulf  = c1 > o1 and c < o and c < o1 and o > c1

// Multi-candle star patterns (bar 2 = signal, bar 1 = small indecision, bar 0 = confirmation)
is_morning_star = c2 < o2 and math.abs(c1 - o1) < math.abs(c2 - o2) * 0.5 and c > o and c > (o2 + c2) / 2
is_evening_star = c2 > o2 and math.abs(c1 - o1) < math.abs(c2 - o2) * 0.5 and c < o and c < (o2 + c2) / 2

// Rejection wicks — strong lower/upper wick with closing in the opposite direction
bull_rejection  = lower_wick >= (2 * body) and c > o
bear_rejection  = upper_wick >= (2 * body) and c < o

// Grouped signals
bull_candle = is_morning_star or is_bull_engulf or bull_rejection or (is_doji and c > o)
bear_candle = is_evening_star or is_bear_engulf or is_shooting_star or bear_rejection or (is_doji and c < o)

// ─── NECKLINE CONFIRMATION ────────────────────────────────────────────────────
// Explicit crossover: close[1] on the other side, close breaks through this bar.
// ta.crossover() is NOT used — it silently fails when a var float goes from na→value.
db_confirmed  = db_pending  and not na(db_neckline)  and close[1] <= db_neckline  and close > db_neckline
dt_confirmed  = dt_pending  and not na(dt_neckline)  and close[1] >= dt_neckline  and close < dt_neckline
ihs_confirmed = ihs_pending and not na(ihs_neckline) and close[1] <= ihs_neckline and close > ihs_neckline
hs_confirmed  = hs_pending  and not na(hs_neckline)  and close[1] >= hs_neckline  and close < hs_neckline

// Snapshot neckline level then clear — labels/lines use the snapshot
if db_confirmed
    db_neck_snap := db_neckline
    db_neckline  := na
    db_pending   := false
if dt_confirmed
    dt_neck_snap := dt_neckline
    dt_neckline  := na
    dt_pending   := false
if ihs_confirmed
    ihs_neck_snap := ihs_neckline
    ihs_neckline  := na
    ihs_pending   := false
if hs_confirmed
    hs_neck_snap := hs_neckline
    hs_neckline  := na
    hs_pending   := false

// ─── PATTERN LABELS ───────────────────────────────────────────────────────────
if show_patterns
    // Chart patterns — neckline break labels + neckline line
    if db_confirmed
        label.new(bar_index, l - candle_range * 0.5, "Double Bottom\nNeckline Break",
          style=label.style_label_up, color=bull_color, textcolor=color.white, size=size.small)
        line.new(bar_index - 20, db_neck_snap, bar_index + 5, db_neck_snap,
          color=bull_color, width=1, style=line.style_dotted)
    if ihs_confirmed
        label.new(bar_index, l - candle_range * 0.5, "Inv H&S\nNeckline Break",
          style=label.style_label_up, color=bull_color, textcolor=color.white, size=size.small)
        line.new(bar_index - 20, ihs_neck_snap, bar_index + 5, ihs_neck_snap,
          color=bull_color, width=1, style=line.style_dotted)
    if dt_confirmed
        label.new(bar_index, h + candle_range * 0.5, "Double Top\nNeckline Break",
          style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
        line.new(bar_index - 20, dt_neck_snap, bar_index + 5, dt_neck_snap,
          color=bear_color, width=1, style=line.style_dotted)
    if hs_confirmed
        label.new(bar_index, h + candle_range * 0.5, "Head & Shoulders\nNeckline Break",
          style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
        line.new(bar_index - 20, hs_neck_snap, bar_index + 5, hs_neck_snap,
          color=bear_color, width=1, style=line.style_dotted)

    // Candlestick rejection labels
    if is_morning_star
        label.new(bar_index, l - candle_range * 0.5, "Morning Star",
          style=label.style_label_up, color=bull_color, textcolor=color.white, size=size.small)
    if is_evening_star
        label.new(bar_index, h + candle_range * 0.5, "Evening Star",
          style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
    if is_shooting_star
        label.new(bar_index, h + candle_range * 0.3, "Shooting Star",
          style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
    if is_doji
        label.new(bar_index, h + candle_range * 0.3, "Doji",
          style=label.style_label_down, color=neutral_color, textcolor=color.white, size=size.small)
    if is_bull_engulf
        label.new(bar_index, l - candle_range * 0.3, "Bull Engulf",
          style=label.style_label_up, color=bull_color, textcolor=color.white, size=size.small)
    if is_bear_engulf
        label.new(bar_index, h + candle_range * 0.3, "Bear Engulf",
          style=label.style_label_down, color=bear_color, textcolor=color.white, size=size.small)
    if bull_rejection and not is_morning_star and not is_bull_engulf
        label.new(bar_index, l - candle_range * 0.3, "Rejection Up",
          style=label.style_label_up, color=color.new(color.green, 30), textcolor=color.white, size=size.small)
    if bear_rejection and not is_evening_star and not is_bear_engulf and not is_shooting_star
        label.new(bar_index, h + candle_range * 0.3, "Rejection Down",
          style=label.style_label_down, color=color.new(color.red, 30), textcolor=color.white, size=size.small)

// ─── ENTRY SIGNALS ────────────────────────────────────────────────────────────
// Bullish trigger: neckline break (chart pattern) OR candlestick rejection
// Bearish trigger: neckline break (chart pattern) OR candlestick rejection
bull_pattern = db_confirmed or ihs_confirmed or bull_candle
bear_pattern = dt_confirmed or hs_confirmed or bear_candle

long_signal  = multi_tf_bull and bullish_structure and bull_pattern and ema_bull
short_signal = multi_tf_bear and bearish_structure and bear_pattern and ema_bear

// ─── PIP SIZE (universal — auto-detect by instrument type) ────────────────────
pip_size = pip_override > 0 ? pip_override :
           syminfo.type == "forex" ? syminfo.mintick * 10 : syminfo.mintick

// ─── TP / SL LEVELS ───────────────────────────────────────────────────────────
if long_signal
    sl_price = low - (aoi_max_pips * pip_size)
    tp_price = close + ((close - sl_price) * 2)
    label.new(bar_index, low,
      "BUY\nSL: " + str.tostring(sl_price, "#.####") + "\nTP: " + str.tostring(tp_price, "#.####"),
      style=label.style_label_up, color=color.new(color.green, 10),
      textcolor=color.white, size=size.normal)
    line.new(bar_index - 1, tp_price, bar_index + 10, tp_price,
      color=bull_color, width=1, style=line.style_dashed)
    line.new(bar_index - 1, sl_price, bar_index + 10, sl_price,
      color=bear_color, width=1, style=line.style_dashed)

if short_signal
    sl_price = high + (aoi_max_pips * pip_size)
    tp_price = close - ((sl_price - close) * 2)
    label.new(bar_index, high,
      "SELL\nSL: " + str.tostring(sl_price, "#.####") + "\nTP: " + str.tostring(tp_price, "#.####"),
      style=label.style_label_down, color=color.new(color.red, 10),
      textcolor=color.white, size=size.normal)
    line.new(bar_index - 1, tp_price, bar_index + 10, tp_price,
      color=bull_color, width=1, style=line.style_dashed)
    line.new(bar_index - 1, sl_price, bar_index + 10, sl_price,
      color=bear_color, width=1, style=line.style_dashed)

// ─── LAST ENTRY TRACKING ──────────────────────────────────────────────────────
var string last_entry       = "None"
var color  last_entry_color = neutral_color

if long_signal
    last_entry       := "LONG"
    last_entry_color := bull_color
if short_signal
    last_entry       := "SHORT"
    last_entry_color := bear_color

// ─── DASHBOARD TABLE ──────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 13,
  bgcolor=color.new(color.black, 65),
  border_color=color.new(color.gray, 50), border_width=1,
  frame_color=color.new(color.gray, 50), frame_width=1)

table.cell(dash, 0, 0,  "Claude Code S&F",  text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 40), text_halign=text.align_left)
table.cell(dash, 1, 0,  "Status",            text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 40), text_halign=text.align_center)

table.cell(dash, 0, 1,  htf1 + " Bias",      text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 1,  htf1_bull ? "Bullish" : "Bearish", text_color=htf1_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 2,  htf2 + " Bias",      text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 2,  htf2_bull ? "Bullish" : "Bearish", text_color=htf2_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 3,  "4H Bias",           text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 3,  htf3_bull ? "Bullish" : "Bearish", text_color=htf3_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 4,  "2H Bias",           text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 4,  htf4_bull ? "Bullish" : "Bearish", text_color=htf4_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 5,  "1H Bias",           text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 5,  htf5_bull ? "Bullish" : "Bearish", text_color=htf5_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 6,  "30m Bias",          text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 6,  htf6_bull ? "Bullish" : "Bearish", text_color=htf6_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 7,  "TF Alignment",      text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 7,
  multi_tf_bull ? "All Bull" : multi_tf_bear ? "All Bear" : str.tostring(tf_bull_count) + "/6 Bull",
  text_color=multi_tf_bull ? bull_color : multi_tf_bear ? bear_color : neutral_color,
  text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 8,  "Structure",         text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 8,
  bullish_structure ? "HH + HL" : bearish_structure ? "LH + LL" : "Mixed",
  text_color=bullish_structure ? bull_color : bearish_structure ? bear_color : neutral_color,
  text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 9,  "EMA " + str.tostring(ema_length), text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 9,  ema_bull ? "Price Above" : "Price Below",
  text_color=ema_bull ? bull_color : bear_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 10, "Max AOI",           text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 10, str.tostring(aoi_max_pips, "#") + " pips",
  text_color=color.white, text_size=size.small, text_halign=text.align_center)

// Row 11 — active pattern (chart patterns take priority over candlestick)
active_pattern      = db_confirmed     ? "Dbl Bottom"  :
                      ihs_confirmed    ? "Inv H&S"     :
                      dt_confirmed     ? "Dbl Top"     :
                      hs_confirmed     ? "H&S"         :
                      is_morning_star  ? "Morning Star":
                      is_evening_star  ? "Evening Star":
                      is_shooting_star ? "Shoot Star"  :
                      is_bull_engulf   ? "Bull Engulf" :
                      is_bear_engulf   ? "Bear Engulf" :
                      is_doji          ? "Doji"        :
                      bull_rejection   ? "Reject Up"   :
                      bear_rejection   ? "Reject Down" : "None"
active_pattern_bull = db_confirmed or ihs_confirmed or bull_candle
active_pattern_bear = dt_confirmed or hs_confirmed or bear_candle
pattern_color       = active_pattern_bull ? bull_color : active_pattern_bear ? bear_color : neutral_color

table.cell(dash, 0, 11, "Last Entry",        text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 11, last_entry,          text_color=last_entry_color, text_size=size.small, text_halign=text.align_center)

table.cell(dash, 0, 12, "Signal",            text_color=color.gray, text_size=size.small, text_halign=text.align_left)
table.cell(dash, 1, 12,
  long_signal ? "LONG" : short_signal ? "SHORT" : "Wait",
  text_color=long_signal ? bull_color : short_signal ? bear_color : neutral_color,
  text_size=size.small, text_halign=text.align_center)

// ─── ALERTS ───────────────────────────────────────────────────────────────────
alertcondition(long_signal,  "Claude Code S&F — Long",  "Long: all TF alignment + HH/HL + bullish pattern neckline break + above EMA")
alertcondition(short_signal, "Claude Code S&F — Short", "Short: all TF alignment + LH/LL + bearish pattern neckline break + below EMA")
